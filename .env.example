# ==============================================
# Task & Schedule Manager - Environment Variables
# ==============================================

# ----------------------------------------------
# Database Configuration
# ----------------------------------------------
# PostgreSQL connection settings
DB_HOST=localhost                    # Database host (use 'postgres' for Docker Compose)
DB_PORT=5432                         # PostgreSQL port
DB_USERNAME=postgres                 # Database username
DB_PASSWORD=postgres                 # Database password (CHANGE IN PRODUCTION!)
DB_DATABASE=task_schedule_manager    # Database name

# ----------------------------------------------
# JWT Authentication Configuration
# ----------------------------------------------
# Secret key for signing JWT tokens (MUST CHANGE IN PRODUCTION!)
JWT_SECRET=dev-secret-key-change-in-production-12345

# JWT token expiration time (examples: 1h, 24h, 7d, 30d)
JWT_EXPIRATION=24h

# ----------------------------------------------
# Application Configuration
# ----------------------------------------------
# Port for the backend API server
PORT=3000

# Node environment (development, production, test)
NODE_ENV=development

# ----------------------------------------------
# Frontend Configuration
# ----------------------------------------------
# Base URL for API requests from frontend
VITE_API_BASE_URL=http://localhost:3000

# ----------------------------------------------
# Docker Compose Configuration
# ----------------------------------------------
# When using Docker Compose, the backend should use:
# DB_HOST=postgres (service name in docker-compose.yml)
#
# When running locally without Docker:
# DB_HOST=localhost

# ----------------------------------------------
# Security Notes
# ----------------------------------------------
# 1. NEVER commit .env file to version control
# 2. ALWAYS change JWT_SECRET in production
# 3. Use strong passwords for DB_PASSWORD in production
# 4. Consider using environment-specific .env files:
#    - .env.development
#    - .env.production
#    - .env.test

# ----------------------------------------------
# Setup Instructions
# ----------------------------------------------
# 1. Copy this file to .env in backend directory:
#    cp .env.example backend/.env
#
# 2. Update the values according to your environment
#
# 3. For Docker Compose, no changes needed (uses defaults)
#
# 4. For local development, ensure PostgreSQL is running:
#    - macOS: brew services start postgresql
#    - Linux: sudo systemctl start postgresql
#    - Windows: Start PostgreSQL service
